NODE_ENV=development
PORT=3000

POSTGRES_USER=clinicsync
POSTGRES_PASSWORD=clinicsync
POSTGRES_DB=clinicsync
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL="postgresql://clinicsync:clinicsync@localhost:5432/clinicsync?schema=public"

JWT_SECRET=change-me-in-production-a-long-random-string
JWT_EXPIRES_IN=1h

DEVICE_JWT_SECRET=change-me-too-another-long-random-string
DEVICE_JWT_EXPIRES_IN=30d

SYNC_PULL_MAX_LIMIT=500
SYNC_FULL_RESYNC_THRESHOLD=50000

THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
